# Supabase Configuration (Required for database-backed pages such as templates)
# Get these from: Supabase Dashboard -> Settings -> API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# GitHub Template Storage (Required only when uploading template ZIPs to GitHub)
# Public preview URLs only need VITE_GITHUB_OWNER. Upload/delete/download management needs a token.
VITE_GITHUB_OWNER=dexlanka-templates
VITE_GITHUB_TOKEN=your-github-token-here

# PayHere Configuration (Required - Primary Payment Gateway)
# Get these from: PayHere Dashboard -> Settings -> API
VITE_PAYHERE_MERCHANT_ID=your_merchant_id
VITE_PAYHERE_MERCHANT_SECRET=your_merchant_secret
VITE_PAYHERE_SANDBOX=true
VITE_SITE_URL=http://localhost:5173

# 2Checkout Configuration (Required - Secondary Payment Gateway)
# Get these from: 2Checkout Dashboard -> Settings -> API
VITE_2CHECKOUT_SELLER_ID=your_seller_id
VITE_2CHECKOUT_SANDBOX=true

# EmailJS Configuration (Required for contact form)
# Get these from: EmailJS Dashboard -> Email Services & Templates
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# EmailJS Reply Template (Optional - for auto-replies)
VITE_EMAILJS_REPLY_TEMPLATE_ID=your_reply_template_id
